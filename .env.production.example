# ─── Bull & Bear — Production environment ──────────────
# Copy this file to .env.production and fill it in.
# DO NOT commit the real .env.production (already in .gitignore).
# Generate the long secrets with: openssl rand -hex 48

# ─── Domain & TLS ───────────────────────────────────────
DOMAIN=yourdomain.com
LETSENCRYPT_EMAIL=you@yourdomain.com

# ─── Frontend ──────────────────────────────────────────
# Public API base URL the browser will call. Must be HTTPS in prod.
NEXT_PUBLIC_API_URL=https://yourdomain.com

# ─── Backend / CORS ────────────────────────────────────
# Comma-separated list of allowed origins (no trailing slash).
CLIENT_URL=https://yourdomain.com

# ─── Postgres ──────────────────────────────────────────
POSTGRES_USER=bullbear
POSTGRES_PASSWORD=replace-with-strong-password
POSTGRES_DB=bullandbear

# ─── JWT secrets (generate with: openssl rand -hex 48) ──
JWT_ACCESS_SECRET=replace-me-with-48-bytes-of-random-hex
JWT_REFRESH_SECRET=replace-me-with-different-48-bytes-of-random-hex
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ─── Bcrypt ────────────────────────────────────────────
BCRYPT_ROUNDS=12

# ─── RabbitMQ ──────────────────────────────────────────
RABBITMQ_USER=bullbear
RABBITMQ_PASSWORD=replace-with-strong-password

# ─── SMTP (optional — worker logs to stdout if unset) ──
# Examples:
#   Mailtrap (dev/test):  smtp.mailtrap.io / 2525 / your-username / your-password
#   Resend:               smtp.resend.com / 465 / resend / re_xxx  (SMTP_SECURE=true)
#   Gmail:                smtp.gmail.com / 587 / your@gmail.com / app-password
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM=Bull & Bear <noreply@yourdomain.com>
