# ─── Database ───────────────────────────────────────────
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/bullandbear?schema=public"

# ─── JWT ────────────────────────────────────────────────
JWT_ACCESS_SECRET="change-me-access-secret-very-long-and-random"
JWT_REFRESH_SECRET="change-me-refresh-secret-very-long-and-random"
JWT_ACCESS_EXPIRES_IN="15m"
JWT_REFRESH_EXPIRES_IN="7d"

# ─── Server ─────────────────────────────────────────────
PORT=4000
NODE_ENV=development
CLIENT_URL="http://localhost:3000"

# ─── Bcrypt ─────────────────────────────────────────────
BCRYPT_ROUNDS=12
